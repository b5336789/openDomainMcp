# Copy to .env and adjust. All settings use the ODM_ prefix.

# Where the Chroma vector store and runtime config are persisted.
ODM_DATA_DIR=.opendomain

# Vector store collection name.
ODM_COLLECTION_NAME=domain_knowledge

# Security: confine ingestion to this directory tree. Paths resolving outside it
# (including via symlinks) are rejected. Leave unset for trusted local use; set
# it when exposing the web/MCP server so callers cannot index arbitrary files.
# ODM_INGEST_ROOT=/srv/knowledge-sources

# Security: reject web uploads larger than this many megabytes.
ODM_MAX_UPLOAD_MB=50

# Embedder backend: local | openai | voyage
ODM_EMBEDDER_BACKEND=local
# Local model (fastembed). 384-dim, no GPU/torch required.
ODM_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
# Optional HTTP Basic Auth for a self-hosted OpenAI-compatible embedding server
# behind a proxy. "user:password"; empty disables it. Header name defaults to
# Authorization (overrides the Bearer key); set a custom header to keep both.
# ODM_EMBEDDER_BASIC_AUTH=user:password
# ODM_EMBEDDER_BASIC_AUTH_HEADER=Authorization

# Domain-knowledge extraction (uses the Anthropic API).
ODM_EXTRACT_KNOWLEDGE=true
ODM_EXTRACTION_MODEL=claude-sonnet-4-6
# Request json_schema structured output (OpenAI backend) so the model cannot emit
# malformed JSON. Prevents extraction failures on endpoints that support it
# cheaply, but constrained decoding is much slower on some local servers — hence
# off by default, with the always-on JSON-repair fallback handling common cases.
ODM_EXTRACT_STRUCTURED_OUTPUT=false

# Text chunking.
ODM_CHUNK_SIZE=1200
ODM_CHUNK_OVERLAP=150

# Code (AST) chunking fallback limits.
ODM_CODE_MAX_CHUNK_CHARS=2000

# Optional cross-encoder re-ranking after fusion (downloads a model on first
# use). Gives a unified relevance score to every result, lexical hits included.
ODM_RERANK_ENABLED=false
ODM_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Knowledge review workflow. When review mode is on, newly extracted knowledge is
# marked "pending" and must be approved (web Review page) before it counts as
# reviewed. When approved-only retrieval is on, search and MCP views return only
# approved knowledge. Both default off.
ODM_REVIEW_MODE=false
ODM_RETRIEVE_APPROVED_ONLY=false

# Relevance floor for the 'ask' RAG path. If the best retrieved chunk's cosine
# similarity is below this, 'ask' refuses ("no content matched") instead of
# answering from weak/irrelevant sources (reduces hallucination on out-of-corpus
# questions). 0.0 = disabled. ~0.65 suits the default embedder; tune per model.
ODM_RETRIEVE_MIN_SCORE=0.0

# Inject a knowledge-graph source into 'ask': when the question names a graph
# entity (or matches a workflow), its edges / ordered steps are added as one
# cited source. Answers relation/sequence questions the chunks don't cover.
# Off by default; no-op when the graph is unwired (NullGraphStore).
ODM_RETRIEVE_INCLUDE_GRAPH=false

# Resilience for external API calls (Anthropic): per-request timeout (seconds)
# and automatic retries on transient errors. Also bounds Chroma store retries.
ODM_REQUEST_TIMEOUT=60
ODM_MAX_RETRIES=2

# --- Knowledge graph store (MariaDB, required) ---
# NOTE: the knowledge-graph tables include a `collection` column in their
# primary keys. This schema is auto-created on first run. If you ran an
# earlier dev build of this branch against MariaDB, DROP the entities,
# entity_chunks, and edges tables once so they are recreated with the new
# schema (CREATE TABLE IF NOT EXISTS will not alter existing tables).
GRAPH_DB_HOST=localhost
GRAPH_DB_PORT=3306
GRAPH_DB_USER=opendomain
GRAPH_DB_PASSWORD=
GRAPH_DB_NAME=opendomain_graph

# --- Access control (RBAC / API keys), default OFF ---
# When ODM_AUTH_ENABLED=true, protected endpoints (e.g. /api/simulate and the
# MCP-endpoint management routes) require an X-API-Key header. Keys map to a role
# and the MCP views they may use. Format: comma-separated entries of
#   key:role:views   where views is "*" (all) or a "|"-separated list.
# Example: ODM_API_KEYS=adminkey:admin:*,devkey:dev:developer|architecture
# ODM_AUTH_ENABLED=false
# ODM_API_KEYS=

# --- Multi-tenancy, default OFF ---
# When ODM_MULTI_TENANT=true, every request must carry an X-Tenant header and each
# tenant's data is isolated by namespacing the collection as <tenant>::<collection>.
# ODM_MULTI_TENANT=false

# --- Logging ---
# Root log level for the structured logger / request middleware.
# ODM_LOG_LEVEL=INFO

# --- Credentials (read from the standard provider env vars) ---
# The Anthropic SDK reads ANTHROPIC_API_KEY / ANTHROPIC_BASE_URL automatically.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# Only needed if ODM_EMBEDDER_BACKEND is set to a cloud provider:
# OPENAI_API_KEY=
# VOYAGE_API_KEY=
